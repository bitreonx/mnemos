{
  "name": "@mnemos/core",
  "version": "0.3.0",
  "description": "Core library for Mnemos — the memory layer for software intelligence",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./copilot": {
      "types": "./dist/copilot.d.ts",
      "import": "./dist/copilot.js"
    },
    "./memory-engine": {
      "types": "./dist/memory-engine/index.d.ts",
      "import": "./dist/memory-engine/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mnemos",
    "memory",
    "ai",
    "codebase",
    "architecture",
    "intelligence"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bitreonx/mnemos.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/bitreonx/mnemos/issues"
  },
  "homepage": "https://getmnemos.vercel.app",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');const p='dist/discipline';fs.mkdirSync(p,{recursive:true});fs.copyFileSync('src/discipline/fable-mindset.md',p+'/fable-mindset.md')\"",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build && npm run build:test && node scripts/run-tests.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.3",
    "graphology": "^0.25.4",
    "graphology-types": "^0.24.8",
    "sql.js": "^1.13.0",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {},
  "devDependencies": {},
  "engines": {
    "node": ">=20"
  }
}
