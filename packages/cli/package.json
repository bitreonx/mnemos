{
  "name": "getmnemos",
  "version": "0.3.0",
  "description": "Get Mnemos — the memory layer for software. One command, instant codebase intelligence.",
  "type": "module",
  "bin": {
    "getmnemos": "./dist/npm.cjs",
    "mnemos": "./dist/npm.cjs"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/npm.cjs",
    "dist/discipline/fable-mindset.md",
    "README.md"
  ],
  "keywords": [
    "mnemos",
    "getmnemos",
    "memory",
    "ai",
    "codebase",
    "architecture",
    "intelligence",
    "cli",
    "cursor",
    "claude",
    "mcp",
    "security",
    "knowledge-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bitreonx/mnemos.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/bitreonx/mnemos/issues"
  },
  "homepage": "https://getmnemos.vercel.app",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node scripts/bundle.mjs",
    "pkg": "node scripts/pkg.mjs",
    "prepare:publish": "node scripts/prepare-npm-publish.mjs",
    "prepublishOnly": "npm run build --prefix ../core && npm run build && node scripts/prepare-npm-publish.mjs",
    "postpublish": "node scripts/strip-publish-deps.mjs restore"
  },
  "dependencies": {
    "@mnemos/core": "*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@yao-pkg/pkg": "^5.16.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
