{
  "name": "mnestis",
  "version": "0.3.3",
  "private": true,
  "description": "The memory layer for software — transform codebases into structured intelligence",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "mnestis": "node packages/cli/dist/index.js",
    "bench": "node mnemos-bench/scorer/run.mjs",
    "bench:express": "node mnemos-bench/scorer/run.mjs express",
    "bench:nestjs": "node mnemos-bench/scorer/run.mjs nestjs",
    "bench:fresh:express": "node mnemos-bench/scripts/fresh.mjs express",
    "bench:fresh:nestjs": "node mnemos-bench/scripts/fresh.mjs nestjs",
    "bench:regression": "node mnemos-bench/scorer/regression.mjs",
    "bench:verify": "node mnemos-bench/scorer/verify.test.mjs",
    "bench:leaderboard": "node mnemos-bench/scorer/leaderboard.mjs",
    "bench:pin": "node mnemos-bench/scripts/pin-fixtures.mjs",
    "bench:verify-gt": "node mnemos-bench/scripts/verify-ground-truth.mjs",
    "bench:cerberus": "node mnemos-bench/scripts/cerberus.mjs",
    "bench:submit": "node mnemos-bench/scorer/submit.mjs",
    "bench:ai-eval": "node mnemos-bench/scorer/ai-eval.mjs",
    "dabt:ui": "node packages/cli/dist/index.js ui --workspace packages/ui/dabt.workspace.json",
    "docs:sync": "npm run build --workspace @mnestis/core && node scripts/sync-docs.mjs",
    "docs:dev": "npm --workspace @mnestis/docs-site run dev",
    "docs:build": "npm --workspace @mnestis/docs-site run build",
    "docs:preview": "npm --workspace @mnestis/docs-site run preview",
    "audit:deps": "npm audit --omit=dev"
  },
  "overrides": {
    "protobufjs": "^7.4.0",
    "tmp": "^0.2.5",
    "cookie": "^0.7.0",
    "uuid": "^11.1.0",
    "react-router": "^7.18.0",
    "react-router-dom": "^7.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
